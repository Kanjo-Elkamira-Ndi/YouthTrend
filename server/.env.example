# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Your db credentials here
DATABASE_URL=postgresql://postgres:yourPassword@localhost:5432/youthtrend_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=youthtrend-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=youthtrend-refresh-secret-key-minimum-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Email (not needed until B3) ───────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@youthtrend.cm

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=youthtrend-better-auth-secret-min-32-chars-ok
BETTER_AUTH_URL=http://localhost:4000

# ── Social OAuth (leave blank until you set up each provider) ─────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=